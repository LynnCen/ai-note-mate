# Firebase (client-safe; used for Firestore real-time sync)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# LLM (server-side only; do not use NEXT_PUBLIC_ for these)
LLM_PROVIDER=openai
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
GML_API_KEY=
# Optional: GML base URL (default: 智谱 https://open.bigmodel.cn/api/paas/v4)
# GML_API_BASE_URL=
# Optional: GML model (default: glm-4-flash)
# GML_MODEL=glm-4-flash
